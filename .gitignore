# ── 보안: API 키 / 시크릿 ──────────────────────────────────────────────
.env
.env.local
*.secret

# ── Python 런타임 ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── 가상환경 ──────────────────────────────────────────────────────────
.venv/
venv/
env/

# ── 텔레그램 세션 (인증 정보 포함) ───────────────────────────────────
*.session
*.session-journal
.telegram_session*

# ── 런타임 상태 파일 (재시작마다 재생성) ─────────────────────────────
positions.json
etc/telegram_listener_state.json
etc/telegram_texts/
etc/naver_research/

# ── 로그 ──────────────────────────────────────────────────────────────
logs/*.log
logs/*.txt

# ── 테스트 캐시 ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDE / 에디터 ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS 생성 파일 ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── 빌드 / 배포 ───────────────────────────────────────────────────────
dist/
build/
*.egg-info/

# ── etc/ 내 민감 파일 (API 키, 봇 토큰, 자격증명) ────────────────────
etc/OPENAI_API_KEY*
etc/httpsapi.*
etc/*claude_key*
etc/*_key.txt
etc/*_key*.txt
etc/powershell*
etc/*API*.txt

# ── Claude Code 내부 데이터 ────────────────────────────────────────────
.claude/

# ── 바이너리 참고 문서 (대용량) ───────────────────────────────────────
etc/*.pdf
