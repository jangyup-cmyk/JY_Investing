# ============================================================
# .env.example — 환경 변수 템플릿 (실제 값 없음, Git 추적 가능)
# 복사 후 .env 또는 .env.local 로 사용하세요.
# 권장: Windows 사용자 환경변수(PS 스크립트)로 설정.
# ============================================================

# --- 계좌 1 ---
KIS_ACCOUNT_NO_JY_Investing1=your_account_no_1
KIS_APP_KEY_JY1=your_app_key_1
KIS_APP_SECRET_JY1=your_app_secret_1
BUDGET_JY1=1000000

# --- 계좌 2 ---
KIS_ACCOUNT_NO_JY_Investing2=your_account_no_2
KIS_APP_KEY_JY2=your_app_key_2
KIS_APP_SECRET_JY2=your_app_secret_2
BUDGET_JY2=1000000

# --- 텔레그램 봇 (개인채널 알림용) ---
TELEGRAM_BOT_TOKEN_JY_Investing1=your_bot_token_1
TELEGRAM_BOT_TOKEN_JY_Investing2=your_bot_token_2
TELEGRAM_CHANNEL_ID_JY_Investing=-100xxxxxxxxxx

# --- 텔레그램 관리자 봇 ---
TELEGRAM_ADMIN_BOT_TOKEN=your_admin_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# --- Telethon (실시간 채널 모니터링) ---
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+82010xxxxxxxx
TELEGRAM_SESSION_FILE=.telegram_session

# --- 텔레그램 모니터링 설정 ---
TELEGRAM_MONITOR_ENABLED=false
TELEGRAM_POLL_INTERVAL=300
TELEGRAM_MESSAGE_FETCH_LIMIT=100
TELEGRAM_MONITOR_FOLDERS=공시속보, 증권사, 경제신문, 분석가

# --- 네이버 리서치 ---
NAVER_RESEARCH_ENABLED=true
NAVER_RESEARCH_POLL_INTERVAL=3600
NAVER_RESEARCH_SOURCE_DIR=etc/naver_research

# --- 매매 파라미터 ---
SLIPPAGE_RATE=0.003
STOP_LOSS_RATE=0.05
TAKE_PROFIT_RATE=0.10
MIN_CHANGE_RATE=2.0
MAX_CHANGE_RATE=15.0
MIN_PRICE=1000
MAX_PRICE=100000

# --- 포트폴리오 리스크 한도 ---
MAX_POSITIONS=5          # 계좌당 최대 동시 보유 종목 수
MIN_CASH_RATE=0.20       # 예산 대비 최소 현금 비율 (20% 미만 시 경고)

# --- Flask 대시보드 ---
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false
